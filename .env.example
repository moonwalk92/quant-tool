# 环境变量配置

# ============== 免费方案（推荐） ==============

# Investing.com 爬虫 - 免费！无需 API Key ⭐
# 爬取 Investing.com 实时价格（黄金、外汇、 crypto）
USE_INVESTING_COM=true

# ============== 付费 API（可选） ==============

# FMP API (Financial Modeling Prep)
# 注册：https://financialmodelingprep.com/pricing ($19/月)
FMP_API_KEY=你的 API key

# Alpha Vantage API
# 注册：https://www.alphavantage.co/support/#api-key (免费)
ALPHA_VANTAGE_API_KEY=你的 API key

# Twelve Data API
# 注册：https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=你的 API key

